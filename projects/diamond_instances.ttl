    rdfs:comment "A software suite for electronic structure calculations based on density functional theory, using pseudopotentials and a plane wave or wavelet basis. Capable of treating metals, insulators, and molecules." ;
    skos:prefLabel "ABINIT" .

:AiiDA rdf:type diam:OpenSource ;
    rdfs:comment "AiiDA (Automated Interactive Infrastructure and Database for Computational Science) is an open-source Python framework for managing, preserving, and disseminating computational scientific workflows. It provides automated provenance tracking, data management, and workflow execution capabilities for high-throughput computational materials science." ;
    skos:prefLabel "AiiDA" ;
    diam:isUsedForDevelopment :AiiDAPluginDevelopment,
        :AiidaWorkflows .

:AiidaN2p2Plugin rdf:type diam:Product ;
    rdfs:label "AiiDA-n2p2 Plugin" ;
    rdfs:comment "An AiiDA plugin for automating the development of Behler-Parrinello neural network MLPs using n2p2, including automated weight selection, validation through LAMMPS molecular dynamics, and semi-automated input generation." ;
    skos:prefLabel "AiiDA-n2p2 Plugin" .

:Apptainer rdf:type diam:OpenSource ;
    rdfs:comment "Apptainer is an open-source container platform. It enables users to create and run containers that encapsulate applications and their dependencies, ensuring portability and reproducibility across diverse computing systems." ;
    skos:prefLabel "Apptainer" .

:AtomicSimulation rdf:type diam:Computational ;
    rdfs:comment "Developing and applying atomistic simulation techniques for materials modelling." ;
    skos:prefLabel "Atomistic Simulation" .

:AtomisticNumericalSimulationDB rdf:type diam:Database ;
    rdfs:comment "Database for atomistic numerical simulations - based on BigDFT code simulation" ;
    skos:prefLabel "Atomistic Numerical Simulations - BigDFT" .

:CEA-MEM rdf:type diam:Partner ;
    rdfs:comment "CEA-MEM (Matter Exploration and Modeling)"@en,
        "CEA-MEM (Laboratoire Modélisation et Exploration des Matériaux)"@fr ;
    skos:prefLabel "CEA-MEM" .

:CEA-IRIG rdf:type diam:Partner ;
    rdfs:comment "CEA-IRIG (Interdisciplinary Research Institute of Grenoble))"@en,
        "CEA-IRIG (Institut de recherche interdisciplinaire de Grenoble)"@fr ;
    skos:prefLabel "CEA-IRIG" .


:Containerization rdf:type diam:Computational ;
    rdfs:comment "Using container technologies to encapsulate, distribute, and execute scientific software in reproducible environments." ;
    skos:prefLabel "Containerization" .

:DFTBPlus rdf:type diam:ScientificComputing ;
    rdfs:comment "A density functional tight-binding code for efficient quantum mechanical calculations on large molecular and materials systems, offering a good balance between accuracy and computational cost." ;
    skos:prefLabel "DFTB+" .

:DatabaseInfrastructure rdf:type diam:DataManagement ;
    rdfs:comment "Building and maintaining backend infrastructure for storing, querying, and scaling access to scientific simulation and experimental data." ;
    skos:prefLabel "Database Infrastructure" .

:DiamondDBConsultationUI rdf:type diam:UserInterface ;
    rdfs:comment "User interface for querying, browsing and visualizing contents of the Diamond database." ;
    skos:prefLabel "Consultation Interface" .

:DiamondDBInfrastructure rdf:type diam:Database ;
    rdfs:comment "Core DIAMOND database and data lake infrastructure deployed at the TGCC-Cloud." ;
    skos:prefLabel "DIAMOND database infrastructure (TGCC-Cloud)",
        "DIAMOND database infrastructure hosted at the TGCC-Cloud" ;
    diam:hasComponent :DiamondDBConsultationUI,
        :DiamondDBInjectionUI,
        :GraphQLEndpoint,
        :GrapheneAPI,
        :KeycloakAuth,
        :MinioDatalake,
        :MongoDBService ;
    diam:hasURL <https:tbc> .

:DiamondDBInjectionUI rdf:type diam:UserInterface ;
    rdfs:comment "Interface for uploading or inserting structured data into the DIAMOND database." ;
    skos:prefLabel "Data Injection Interface" .

:FAIRDataHandling rdf:type diam:DataManagement ;
    rdfs:comment "Applying FAIR principles to ensure that research data is Findable, Accessible, Interoperable, and Reusable." ;
    skos:prefLabel "FAIR Data Handling" .

:FEniCS rdf:type diam:ScientificComputing ;
    rdfs:comment "An open-source computing platform for solving partial differential equations using the finite element method, with automated solution of variational problems and high-level Python interfaces." ;
    skos:prefLabel "FEniCS" .

:FreeFEM rdf:type diam:ScientificComputing ;
    rdfs:comment "A partial differential equation solver using the finite element method. Widely used for multiphysics simulations in fluid dynamics, structural mechanics, and electromagnetics." ;
    skos:prefLabel "FreeFEM" .

:GaTewAY rdf:type diam:ScientificComputing ;
    rdfs:comment "A workflow management system for computational materials science, designed to facilitate automated execution of complex simulation workflows and integration with high-performance computing resources." ;
    skos:prefLabel "GaTewAY" .

:Gmsh rdf:type diam:ScientificComputing ;
    rdfs:comment "A three-dimensional finite element mesh generator with built-in pre- and post-processing facilities, widely used for computational modeling in engineering and physics." ;
    skos:prefLabel "Gmsh" .

:GraphQLEndpoint rdf:type diam:BackendService ;
    rdfs:comment "GraphQL endpoint providing structured access to the DIAMOND data backend." ;
    skos:prefLabel "GraphQL endpoint" .

:GrapheneAPI rdf:type diam:BackendService ;
    rdfs:comment "Python GraphQL API implemented using Graphene." ;
    skos:prefLabel "Graphene API" .

:GrenobleINP rdf:type diam:Partner ;
    rdfs:comment "Grenoble INP" ;
    skos:prefLabel "Grenoble INP" .

:Guix rdf:type diam:OpenSource ;
    rdfs:comment "GNU Guix is a functional package manager that facilitates the creation of reproducible and declarative software environments. It allows users to define complete software environments that can be shared and replicated across different systems, enhancing reproducibility in software deployment." ;
    skos:prefLabel "Guix" .

:GuixPackaging rdf:type diam:Computational ;
    rdfs:comment "Creating and maintaining Guix packages to ensure reproducible software environments for scientific computing." ;
    skos:prefLabel "Guix Packaging" .

:KeycloakAuth rdf:type diam:BackendService ;
    rdfs:comment "Identity and access management layer using Keycloak for authentication and authorization." ;
    skos:prefLabel "Keycloak authentication service" .

:MLIP rdf:type diam:Computational ;
    rdfs:comment "Using and developing ML-based interatomic potentials for atomistic simulations, including training, validation, and workflow integration." ;
    skos:prefLabel "Machine Learning Interatomic Potentials" .

:MLIPDB rdf:type diam:Database ;
    rdfs:comment "Machine Learning Interatomic Potentials database - an open-access web repository where external users can submit new MLP models and download MLP parameterizations." .

:MLPValidation rdf:type diam:Methodological ;
    rdfs:comment "Expertise in validation methods for machine learning potentials, including biased molecular dynamics, phonon-based sampling, and benchmark testing." ;
    skos:prefLabel "MLP Validation Methods" .

:MLWorkflowDesign rdf:type diam:Methodological ;
    rdfs:comment "Designing ML workflows involving data preparation, feature engineering, training, validation, and deployment for scientific tasks." ;
    skos:prefLabel "Machine Learning Workflow Design" .

:MOF rdf:type diam:Competence ;
    rdfs:comment "Expertise in the chemistry, structure, modelling, or application of metal-organic frameworks." ;
    skos:prefLabel "Metal-Organic Frameworks" .

:MinioDatalake rdf:type diam:StorageService ;
    rdfs:comment "Object storage solution for experimental and computational datasets, used as DIAMOND's data lake." ;
    skos:prefLabel "MinIO data lake" .

:MongoDB rdf:type diam:OpenSource ;
    rdfs:comment "MongoDB is a document-oriented NoSQL database that stores data in flexible, JSON-like documents. It offers scalability and flexibility for handling large volumes of unstructured or semi-structured data, making it suitable for modern application development." ;
    skos:prefLabel "MongoDB" ;
    diam:isUsedForDevelopment diam:Database .

:MongoDBService rdf:type diam:BackendService ;
    rdfs:comment "MongoDB instance used for DIAMOND's metadata store and backend infrastructure." ;
    skos:prefLabel "MongoDB backend" .

:NWChem rdf:type diam:ScientificComputing ;
    rdfs:comment "A computational chemistry software designed for calculations on molecular systems of varying sizes, from small molecules to biomolecules and materials, using quantum mechanical and classical methods." ;
    skos:prefLabel "NWChem" .

:Neper rdf:type diam:ScientificComputing ;
    rdfs:comment "A software package for polycrystal generation and meshing, designed to create representative volume elements of polycrystalline materials for finite element simulations." ;
    skos:prefLabel "Neper" .

:NeuralNetworkPotentials rdf:type diam:Computational ;
    rdfs:comment "Expertise in Behler-Parrinello neural network architectures and other neural network-based interatomic potentials for atomistic simulations." ;
    skos:prefLabel "Neural Network Potentials" .

:OpenCalphad rdf:type diam:ScientificComputing ;
    rdfs:comment "An open-source thermodynamic software for CALPHAD (CALculation of PHAse Diagrams) calculations, used for predicting phase equilibria and thermodynamic properties of multicomponent systems." ;
    skos:prefLabel "OpenCalphad" .

:OpenDiS rdf:type diam:ScientificComputing ;
    rdfs:comment "An open-source dislocation dynamics simulation code for modeling plastic deformation in crystalline materials through the collective motion of dislocations." ;
    skos:prefLabel "OpenDiS" .

:Ovito rdf:type diam:Visualization ;
    rdfs:comment "Open Visualization Tool - A scientific visualization and analysis software for atomistic and particle simulation data, particularly suited for molecular dynamics and discrete element simulations." ;
    skos:prefLabel "OVITO" ;
    diam:hasURL <https://diamond-diadem.github.io/codes/visualisation/ovito/> .

:PLUMED rdf:type diam:ScientificComputing ;
    rdfs:comment "An open-source plugin for free energy calculations in molecular dynamics, enabling enhanced sampling methods and analysis of molecular simulations across multiple MD codes." ;
    skos:prefLabel "PLUMED" .

:ParaView rdf:type diam:Visualization ;
    rdfs:comment "An open-source, multi-platform data analysis and visualization application for large-scale scientific datasets, supporting various data formats and offering advanced visualization capabilities for finite element and computational fluid dynamics results." ;
    skos:prefLabel "ParaView" ;
    diam:hasURL <https://diamond-diadem.github.io/codes/visualisation/paraview/> .

:QuantumESPRESSO rdf:type diam:ScientificComputing ;
    rdfs:comment "An integrated suite of open-source codes for electronic-structure calculations and materials modeling at the nanoscale, based on density-functional theory, plane waves, and pseudopotentials." ;
    skos:prefLabel "Quantum ESPRESSO" ;
    diam:hasURL <https://diamond-diadem.github.io/codes/scientific-computing/quantum-espresso/> .

:RASPA2 rdf:type diam:ScientificComputing ;
    rdfs:comment "A molecular simulation software for adsorption and diffusion in nanoporous materials, particularly metal-organic frameworks (MOFs) and zeolites, using Monte Carlo and molecular dynamics methods." ;
    skos:prefLabel "RASPA2" .

:VESTA rdf:type diam:Visualization ;
    rdfs:comment "Visualization for Electronic and STructural Analysis - A 3D visualization program for structural models, volumetric data such as electron/nuclear densities, and crystal morphologies, widely used in materials science and crystallography." ;
    skos:prefLabel "VESTA" .

:VMD rdf:type diam:Visualization ;
    rdfs:comment "Visual Molecular Dynamics - A molecular visualization program for displaying, animating, and analyzing large biomolecular systems using 3D graphics and built-in scripting for trajectory analysis." ;
    skos:prefLabel "VMD" .

:Wannier90 rdf:type diam:ScientificComputing ;
    rdfs:comment "A code for generating maximally-localized Wannier functions from electronic structure calculations, used for analyzing chemical bonding and calculating transport properties." ;
    skos:prefLabel "Wannier90" .

:WebDevelopment rdf:type diam:Methodological ;
    rdfs:comment "Design and implementation of user-facing web applications for presenting, accessing, or submitting scientific data and workflows." ;
    skos:prefLabel "Web Application Development" .

:WorkflowOrchestration rdf:type diam:Methodological ;
    rdfs:comment "Coordinating and managing computational workflows using orchestration tools such as CWL, Nextflow, or Airflow." ;
    skos:prefLabel "Workflow Orchestration" .

:XCrySDen rdf:type diam:Visualization ;
    rdfs:comment "X-window CRYstalline Structures and DENsities - A crystalline and molecular structure visualization program for displaying isosurfaces, contours, and atomic structures, with support for various quantum chemistry and solid-state physics codes." ;
    skos:prefLabel "XCrySDen" .

:XTB rdf:type diam:ScientificComputing ;
    rdfs:comment "An extended tight-binding semi-empirical quantum chemistry program for efficiently calculating structures, properties, and reaction paths of molecular systems containing thousands of atoms." ;
    skos:prefLabel "XTB" .

:ZeoPlusPlus rdf:type diam:ScientificComputing ;
    rdfs:comment "A software package for high-throughput analysis of porous materials and crystal structures, calculating geometric properties such as surface area, pore volume, and accessible channels." ;
    skos:prefLabel "Zeo++" .

:Zset rdf:type diam:ScientificComputing ;
    rdfs:comment "A finite element-based software suite for nonlinear material and structure analysis, particularly focused on thermomechanical simulations and advanced material behavior modeling." ;
    skos:prefLabel "Z-set" .

:AiiDAPluginDevelopment rdf:type diam:Computational ;
    rdfs:comment "Development of AiiDA plugins to interface scientific simulation codes with automated workflow engines." ;
    skos:prefLabel "AiiDA Plugin Development" .

:AiidaWorkflows rdf:type diam:Computational ;
    rdfs:comment "Design and execution of automated and reproducible scientific workflows using the AiiDA computational framework." ;
    skos:prefLabel "AiiDA Workflows" .

:CEASaclay rdf:type diam:Partner .

:CP2K rdf:type diam:ScientificComputing ;
    rdfs:comment "A quantum chemistry and solid-state physics software package for atomistic simulations, particularly efficient for molecular dynamics simulations using mixed Gaussian and plane wave methods." ;
    skos:prefLabel "CP2K" .

:LAMMPS rdf:type diam:ScientificComputing ;
    rdfs:comment "Large-scale Atomic/Molecular Massively Parallel Simulator. A classical molecular dynamics code for simulating materials, soft matter, and biological systems at the atomic scale." ;
    skos:prefLabel "LAMMPS" ;
    diam:hasURL <https://diamond-diadem.github.io/codes/scientific-computing/lammps/> .

:LargeScaleWorkflows rdf:type diam:Computational ;
    rdfs:comment "Design and execution of large-scale computational workflows running across distributed or HPC infrastructures." ;
    skos:prefLabel "Large-scale Workflows" .

:MetadataStandardization rdf:type diam:DataManagement ;
    rdfs:comment "Defining, adopting, and applying metadata schemas to improve data interoperability and reusability." ;
    skos:prefLabel "Metadata Standardization" .

:n2p2 rdf:type diam:ScientificComputing ;
    rdfs:comment "A software package for training and applying high-dimensional neural network potentials for atomistic simulations, enabling accurate and efficient molecular dynamics with machine learning potentials." ;
    skos:prefLabel "n2p2" .

:CEA-SRMP rdf:type diam:Partner ;
    rdfs:comment "CEA-SRMP (Service de Recherches de Métallurgie Physique)"@fr ;
    skos:prefLabel "CEA-SRMP" .

:GRICAD rdf:type diam:Partner ;
    rdfs:comment "Grenoble Alpes Research Scientific Computing and Data Infrastructure"@en,
        "Grenoble Alpes Recherche - Infrastructure de Calcul intensif et de Données"@fr ;
    skos:prefLabel "GRICAD" .

:ILM rdf:type diam:Partner ;
    rdfs:comment "The Institut Lumière Matière"@fr ;
    skos:prefLabel "iLM" .

:AIApproaches rdf:type diam:Methodological ;
    rdfs:comment "General methodological approaches based on artificial intelligence for analysis, prediction, or automation in scientific research." ;
    skos:prefLabel "AI Approaches" .

:Diamond rdf:type diam:Project ;
    rdfs:comment "Ontology representing all entities of the DIAMOND project" ;
    skos:prefLabel "DIAMOND Project" ;
    diam:hasWorkPackage :WP1,
        :WP2,
        :WP3 .

:IMPMC rdf:type diam:Partner ;
    rdfs:comment "Institut de Minéralogie, de Physique des Matériaux et de Cosmochimie"@fr ;
