:Sorbonne rdf:type diam:Partner ;
    rdfs:comment "Sorbonne Universite" ;
    skos:prefLabel "Sorbonne University" .

:CEA-SGLS rdf:type diam:Partner ;
    rdfs:comment "CEA-SGLS (Service de Génie Logiciel pour la Simulation)" ;
    skos:prefLabel "CEA-SGLS" .

:SIMAP rdf:type diam:Partner ;
