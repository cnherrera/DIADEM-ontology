                 "Science and Engineering of Materials and Processes"@en ;
    skos:prefLabel "SIMaP" .

:CEA-LIST rdf:type diam:Partner ;
    rdfs:comment "CEA-LIST (Laboratoire d'Intégration de Systèmes et des Technologies)"@fr ;
    skos:prefLabel "CEA-LIST" .

:WP3 rdf:type diam:WorkPackage ;
    rdfs:comment "Machine-learning Interatomic-potential demonstrator. Delivers an open-access repository of MLPs, builds a platform for MLP development including automated training dataset generation, common interface for MLP packages, and containerized workflow solutions." ;
    skos:prefLabel "WP3 - MLIP demonstrator" ;
    diam:coLedBy :SIMAP ;
    diam:gathersCompetence :AIApproaches,
        :AIBasedModelling,
        :AiiDAPluginDevelopment,
        :AiidaWorkflows,
        :AtomicSimulation,
        :MLIP,
        :MLPValidation,
        :MLWorkflowDesign,
        :NeuralNetworkPotentials ;
    diam:ledBy :IMPMC ;
    diam:partOf :Diamond ;
    diam:produces :AiidaN2p2Plugin,
        :MLIPDB,
        :WorkflowPlatform ,
        :MLPWorkflowPlatform ;
    diam:usesTool :AiiDA,
        :CP2K,
        :LAMMPS,
        :n2p2 .

:WP2 rdf:type diam:WorkPackage ;
    rdfs:comment "Design and implementation of data management infrastructure for the DIAMOND project" ;
    skos:prefLabel "WP2 - Data Management" ;
    diam:coLedBy :CEA-LIST ;
    diam:gathersCompetence :AIApproaches,
        :DatabaseInfrastructureDesign,
        :DatabaseInfrastructure,
        :FAIRDataHandling,
        :LargeScaleWorkflows,
        :MetadataStandardization,
        :WorkflowOrchestration ;
    diam:ledBy :CEA-IRIG ;
    diam:hasScientificResponsable :THIERRY_DEUTSCH ;
    diam:partOf :Diamond ;
    diam:produces :DiamondDBInfrastructure,
                  :AtomisticNumericalSimulationDB,
                  :Fast2NanoDB ;
    diam:usesTool :MongoDB .

:WP1 rdf:type diam:WorkPackage ;
    rdfs:comment "Development of the code and workflow platform for the DIAMOND project."@en ,
                 "Development de la platforme codes et workflows pour le projet DIAMOND."@fr ;
    skos:prefLabel "WP1 - Codes and Workflows" ;
