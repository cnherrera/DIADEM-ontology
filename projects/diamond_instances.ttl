@prefix diam: <https://cnherrera.github.io/DIADEM-ontology/projects/project_ontology.ttl#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix eurio:  <http://data.europa.eu/s66#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix : <https://cnherrera.github.io/DIADEM-ontology/projects/diamond_instances.ttl#> .


<https://cnherrera.github.io/DIADEM-ontology/projects/diamond_instances.ttl> rdf:type owl:Ontology ;
    owl:imports <https://cnherrera.github.io/DIADEM-ontology/projects/project_ontology.> ;
    rdfs:comment "Instances DIAMOND project" ;
    owl:versionInfo "0.1" .


#################################################################
#     Instances of the DIAMOND project
#################################################################

:Diamond rdf:type diam:Project ;
    rdfs:label "DIAMOND Project" ;
    diam:hasWorkPackage :WP1 , :WP2 , :WP3 ;
    skos:prefLabel "Ontology representing all entities of the DIAMOND project" .


# ----> Instances of WPs <----
:WP1 rdf:type diam:WorkPackage ;
    diam:partOf :Diamond ;
    diam:gathersCompetence :Containerization , :WebDevelopment , :AIApproaches , :GuixPackaging , :MOF ;
    diam:usesTool :Apptainer , :Guix ;
    diam:produces :DIAMONDWebpage , :LAMMPS , 
                  :QuantumESPRESSO , :Abinit ,
                  :Zset , :FreeFEM ,
                  :OpenCalphad , :Neper ,
                  :PLUMED , :Gmsh ,
                  :ZeoPlusPlus , :RASPA2 ,
                  :OpenDiS , :Wannier90 ,
                  :NWChem , :FEniCS ,
                  :CP2K , :n2p2 ,
                  :DFTBPlus , :XTB ,
                  :GaTewAY , :Ovito ,
                  :ParaView , :VESTA ,
                  :VMD , :XCrySDen ;
                  :ledBy :SIMAP ;
    diam:coLedBy :ILM , :IMPMC ;
    rdfs:comment "Development of the code and workflow platform for the DIAMOND project." ;
    skos:prefLabel "WP1 - Codes and Workflows" .

:WP2 rdf:type diam:WorkPackage ;
    diam:partOf :Diamond ;
    diam:gathersCompetence :DatabaseInfrastructure , 
                           :LargeScaleWorkflows ,
                           :AIApproaches ,
                           :MetadataStandardization ,
                           :FAIRDataHandling ,
                           :WorkflowOrchestration ;
    diam:usesTool :MongoDB ;
    diam:produces :DiamondDBInfrastructure ;
    diam:ledBy :CEA-MEM ;
    diam:coLedBy :CEA-LIST ;
    rdfs:comment "Design and implementation of data management infrastructure for the DIAMOND project" ;
    skos:prefLabel "WP2 - Data Management" .


:WP3 rdf:type diam:WorkPackage ;
    diam:partOf :Diamond ;
    diam:gathersCompetence :MLIP ,
                           :AIApproaches ,
                           :AIBasedModelling ,
			   :AiidaWorkflows ,
			   :AiiDAPluginDevelopment ,
                           :MLWorkflowDesign ,
                           :AtomicSimulation ,
			   :NeuralNetworkPotentials ,
			   :MLPValidation ;
    diam:usesTool :AiiDA , :n2p2 , :LAMMPS , :CP2K ;
    diam:produces :MLIPDB , :AiidaN2p2Plugin , :WorkflowPlatform  ;
    diam:ledBy :IMPMC ;
    diam:coLedBy :SIMAP ;
    rdfs:comment "Machine-learning Interatomic-potential demonstrator. Delivers an open-access repository of MLPs, builds a platform for MLP development including automated training dataset generation, common interface for MLP packages, and containerized workflow solutions." ;
    skos:prefLabel "WP3 - MLIP demonstrator" .
    
###########################################
### --- Personnel Type Instances ---

:Scientific rdf:type diam:PersonnelType ;
    rdfs:label "Scientific"@en , "Scientifique"@fr ;
    rdfs:comment "A scientific contributor in the project." .

:ScientificResponsable rdf:type diam:PersonnelType ;
    rdfs:label "Scientific Responsable"@en , "Responsable Scientifique"@fr ;
    rdfs:comment "A scientific lead or responsible person within the project." .

:Engineer rdf:type diam:PersonnelType ;
    rdfs:label "Engineer"@en , "Ingénieur"@fr ;
    rdfs:comment "An engineer contributing to the project." .

:ProjectCoordinator rdf:type diam:PersonnelType ;
    rdfs:label "Project Coordinator"@en , "Coordinateur de Projet"@fr ;
    rdfs:comment "A coordinator overseeing project activities and organization." .

################################################################
# Tasks

# Example Task instance
:Task3_3 rdf:type diam:Task ;
    diam:taskName "Integration of tools for descriptors" ;
    diam:isTaskOf :WP3 ;
    diam:taskLead :SIMAP ;
    diam:taskCoLead :IMPMC , :CEA-SRMP ;
#    diam:taskProduces :XXXX ;
    rdfs:comment "info" ;
    skos:prefLabel "Task 3.3" .



# ----> Instances Competences <----
:NeuralNetworkPotentials a diam:Computational ;
    skos:prefLabel "Neural Network Potentials" ;
    rdfs:comment "Expertise in Behler-Parrinello neural network architectures and other neural network-based interatomic potentials for atomistic simulations." .

:MLPValidation a diam:Methodological ;
    skos:prefLabel "MLP Validation Methods" ;
    rdfs:comment "Expertise in validation methods for machine learning potentials, including biased molecular dynamics, phonon-based sampling, and benchmark testing." .
    
:WebDevelopment a diam:Methodological ;
    skos:prefLabel "Web Application Development" ;
    rdfs:comment "Design and implementation of user-facing web applications for presenting, accessing, or submitting scientific data and workflows." .

:AIApproaches a diam:Methodological ;
    skos:prefLabel "AI Approaches" ;
    rdfs:comment "General methodological approaches based on artificial intelligence for analysis, prediction, or automation in scientific research." .

:AIBasedModelling a diam:Methodological ;
    skos:prefLabel "AI-based Modelling" ;
    rdfs:comment "Application of artificial intelligence techniques to accelerate and enhance materials modelling and discovery." .

:MLWorkflowDesign a diam:Methodological ;
    skos:prefLabel "Machine Learning Workflow Design" ;
    rdfs:comment "Designing ML workflows involving data preparation, feature engineering, training, validation, and deployment for scientific tasks." .

:WorkflowDesign a diam:Methodological ;
    skos:prefLabel "Workflow Design" ;
    rdfs:comment "Structuring scientific and computational procedures into reproducible workflows." .

:WorkflowOrchestration a diam:Methodological ;
    skos:prefLabel "Workflow Orchestration" ;
    rdfs:comment "Coordinating and managing computational workflows using orchestration tools such as CWL, Nextflow, or Airflow." .

:DatabaseInfrastructure a diam:DataManagement ;
    skos:prefLabel "Database Infrastructure" ;
    rdfs:comment "Building and maintaining backend infrastructure for storing, querying, and scaling access to scientific simulation and experimental data." .

:DatabaseInfrastructureDesign a diam:DataManagement ;
    skos:prefLabel "Database Infrastructure Design" ;
    rdfs:comment "Designing the architecture and implementation of scalable and reliable database systems for scientific workflows." .

:FAIRDataHandling a diam:DataManagement ;
    skos:prefLabel "FAIR Data Handling" ;
    rdfs:comment "Applying FAIR principles to ensure that research data is Findable, Accessible, Interoperable, and Reusable." .

:MetadataStandardization a diam:DataManagement ;
    skos:prefLabel "Metadata Standardization" ;
    rdfs:comment "Defining, adopting, and applying metadata schemas to improve data interoperability and reusability." .

:AiidaWorkflows a diam:Computational ;
    skos:prefLabel "AiiDA Workflows" ;
    rdfs:comment "Design and execution of automated and reproducible scientific workflows using the AiiDA computational framework." .

:AiiDAPluginDevelopment a diam:Computational ;
    skos:prefLabel "AiiDA Plugin Development" ;
    rdfs:comment "Development of AiiDA plugins to interface scientific simulation codes with automated workflow engines." .

:AtomicSimulation a diam:Computational ;
    skos:prefLabel "Atomistic Simulation" ;
    rdfs:comment "Developing and applying atomistic simulation techniques for materials modelling." .

:ContainerDeployment a diam:Computational ;
    skos:prefLabel "Scientific Software Containerization" ;
    rdfs:comment "Packaging and deploying scientific software using container technologies such as Apptainer or Docker." .

:GuixPackaging a diam:Computational ;
    skos:prefLabel "Guix Packaging" ;
    rdfs:comment "Creating and maintaining Guix packages to ensure reproducible software environments for scientific computing." .

:HighPerformanceComputing a diam:Computational ;
    skos:prefLabel "High-performance Computing" ;
    rdfs:comment "Using and optimizing scientific codes for execution on high-performance computing infrastructures, including GPU clusters and parallel systems." .

:LargeScaleWorkflows a diam:Computational ;
    skos:prefLabel "Large-scale Workflows" ;
    rdfs:comment "Design and execution of large-scale computational workflows running across distributed or HPC infrastructures." .

:Containerization a diam:Computational ;
    skos:prefLabel "Containerization" ;
    rdfs:comment "Using container technologies to encapsulate, distribute, and execute scientific software in reproducible environments." .

:MLIP a diam:Computational ;
    skos:prefLabel "Machine Learning Interatomic Potentials" ;
    rdfs:comment "Using and developing ML-based interatomic potentials for atomistic simulations, including training, validation, and workflow integration." .


:MOF a diam:Competence ;
    skos:prefLabel "Metal-Organic Frameworks" ;
    rdfs:comment "Expertise in the chemistry, structure, modelling, or application of metal-organic frameworks." .



# ----> Instances database <----

:MLIPDB rdf:type diam:Database ;
    rdfs:comment "Machine Learning Interatomic Potentials database - an open-access web repository where external users can submit new MLP models and download MLP parameterizations." .

:Fast2NanoDB rdf:type  diam:Database ;
    rdfs:comment "Fast2Nano database" .

:AtomisticNumericalSimulationDB rdf:type  diam:Database ;
    skos:prefLabel  "Atomistic Numerical Simulations - BigDFT" ;
    rdfs:comment "Database for atomistic numerical simulations - based on BigDFT code simulation" .


#-----
:DiamondWebpage rdf:type diam:Webpage ;
    rdfs:comment "DIAMOND Web page giving users access to all the containers of codes and workflows." ;
    skos:prefLabel "DIAMOND Project Webpage" ;
    diam:hasURL <https://diamond-diadem.github.io/> .

:DiamondDBInfrastructure rdf:type diam:Database ;
    skos:prefLabel "DIAMOND database infrastructure hosted at the TGCC-Cloud" ;
    diam:hasURL <https:tbc> .

:DiamondDBInfrastructure rdf:type diam:Database ;
    skos:prefLabel "DIAMOND database infrastructure (TGCC-Cloud)" ;
    rdfs:comment "Core DIAMOND database and data lake infrastructure deployed at the TGCC-Cloud." ;
    diam:hasURL <https:tbc> ;
    diam:hasComponent :DiamondDBConsultationUI ,
                      :DiamondDBInjectionUI ,
                      :MongoDBService ,
                      :MinioDatalake ,
                      :GrapheneAPI ,
                      :GraphQLEndpoint ,
                      :KeycloakAuth .

:DiamondDBConsultationUI rdf:type diam:UserInterface ;
    skos:prefLabel "Consultation Interface" ;
    rdfs:comment "User interface for querying, browsing and visualizing contents of the Diamond database." .

:DiamondDBInjectionUI rdf:type diam:UserInterface ;
    skos:prefLabel "Data Injection Interface" ;
    rdfs:comment "Interface for uploading or inserting structured data into the DIAMOND database." .

:MongoDBService rdf:type diam:BackendService ;
    skos:prefLabel "MongoDB backend" ;
    rdfs:comment "MongoDB instance used for DIAMOND's metadata store and backend infrastructure." .

:MinioDatalake rdf:type diam:StorageService ;
    skos:prefLabel "MinIO data lake" ;
    rdfs:comment "Object storage solution for experimental and computational datasets, used as DIAMOND's data lake." .

:GrapheneAPI rdf:type diam:BackendService ;
    skos:prefLabel "Graphene API" ;
    rdfs:comment "Python GraphQL API implemented using Graphene." .

:GraphQLEndpoint rdf:type diam:BackendService ;
    skos:prefLabel "GraphQL endpoint" ;
    rdfs:comment "GraphQL endpoint providing structured access to the DIAMOND data backend." .

:KeycloakAuth rdf:type diam:BackendService ;
    skos:prefLabel "Keycloak authentication service" ;
    rdfs:comment "Identity and access management layer using Keycloak for authentication and authorization." .

#Jupyter Colab (solution for jupyte notebooks hosted in git;ab serverr. Access to AI dedicated tools. Deployed at gricad  and tcgg-cloud 

# ----> Instances Software <----

:AiiDA rdf:type diam:OpenSource ;
    rdfs:comment "AiiDA (Automated Interactive Infrastructure and Database for Computational Science) is an open-source Python framework for managing, preserving, and disseminating computational scientific workflows. It provides automated provenance tracking, data management, and workflow execution capabilities for high-throughput computational materials science." ;
    skos:prefLabel "AiiDA" ;
    diam:isUsedForDevelopment :AiidaWorkflows , :AiiDAPluginDevelopment .
    
:Guix rdf:type  diam:OpenSource ;
    rdfs:comment "GNU Guix is a functional package manager that facilitates the creation of reproducible and declarative software environments. It allows users to define complete software environments that can be shared and replicated across different systems, enhancing reproducibility in software deployment." ;
    skos:prefLabel "Guix" .

:Apptainer rdf:type  diam:OpenSource ;
    rdfs:comment "Apptainer is an open-source container platform. It enables users to create and run containers that encapsulate applications and their dependencies, ensuring portability and reproducibility across diverse computing systems." ;
    skos:prefLabel "Apptainer" .

:BigDFTsim rdf:type diam:OpenSource ;
    rdfs:comment "BigDFT is an open-source electronic structure code based on density functional theory (DFT) that utilizes Daubechies wavelets as a computational basis. It is designed for ab initio simulations of materials and molecular systems, offering high precision and scalability for large-scale simulations." ;
    skos:prefLabel "BigDFT" ;
    diam:isUsedForDevelopment :AtomisticNumericalSimulationDB .

:MongoDB rdf:type  diam:OpenSource ;
    rdfs:comment "MongoDB is a document-oriented NoSQL database that stores data in flexible, JSON-like documents. It offers scalability and flexibility for handling large volumes of unstructured or semi-structured data, making it suitable for modern application development." ;
    skos:prefLabel "MongoDB" ;
    diam:isUsedForDevelopment diam:Database .

#----------

:MLPWebRepository rdf:type diam:Webpage ;
    rdfs:label "MLP Web Repository" ;
    skos:prefLabel "Machine Learning Potential Repository" ;
    rdfs:comment "An open-access web repository where external users can submit new MLP models and download MLP parameterizations." .

:AiidaN2p2Plugin rdf:type diam:Product ;
    rdfs:label "AiiDA-n2p2 Plugin" ;
    skos:prefLabel "AiiDA-n2p2 Plugin" ;
    rdfs:comment "An AiiDA plugin for automating the development of Behler-Parrinello neural network MLPs using n2p2, including automated weight selection, validation through LAMMPS molecular dynamics, and semi-automated input generation." .

:MLPWorkflowPlatform rdf:type diam:Product ;
    rdfs:label "MLP Workflow Platform" ;
    skos:prefLabel "MLP Development Workflow Platform" ;
    rdfs:comment "A containerized workflow solution for MLP development, including automated generation of training, validation and test datasets, and integration with ab initio calculation engines." .



