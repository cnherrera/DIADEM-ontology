@prefix proj:     <https://cnherrera.github.io/DIADEM-ontology/pepr-ontology.ttl#> .
@prefix owl:      <http://www.w3.org/2002/07/owl#> .
@prefix rdf:      <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:     <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos:     <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd:      <http://www.w3.org/2001/XMLSchema#> .
@prefix dc:       <http://purl.org/dc/elements/1.1/> .
@prefix schema:   <https://www.schema.org/> .
@prefix inst:     <https://cnherrera.github.io/DIADEM-ontology/PEPR-DIADEM_instances.ttl#> .

<https://cnherrera.github.io/DIADEM-ontology/PEPR-DIADEM_instances.ttl#> rdf:type owl:Ontology ;
    owl:imports <https://cnherrera.github.io/DIADEM-ontology/pepr-ontology.ttl#> ;
    rdfs:label "PEPR DIADEM Instances – People, Institutions, Projects, and Platforms"@en ,
               "Instances du projet PEPR DIADEM – Personnes, institutions, projets et plateformes"@fr ;
    dc:description "Instances for the PEPR DIADEM project, encompassing people and institutions involved in the project, as well as associated projects and platforms."@en ,
                   "Instances pour le projet PEPR DIADEM, englobant les personnes et les institutions impliquées dans le projet, ainsi que les projets et plateformes associés."@fr ;
    owl:versionInfo "1.0" .



inst:DIADEM rdf:type proj:Program ;
    rdfs:label "Priority research program and equipment on the development of innovative materials using artificial intelligence"^^xsd:string ;
    proj:acronym "PEPR-DIADEM"^^xsd:string ;
    proj:description """A French PEPR program focused on …
"""^^xsd:string ;
    proj:documentationURL "https://pepr-diadem.fr"^^xsd:anyURI ;
    proj:endDate "2030-12-31"^^xsd:date ;
    proj:hasCoLeadInstitution <https://cnherrera.github.io/DIADEM-ontology/proj#org/CEA> ;
    proj:hasCoLeadPerson <https://cnherrera.github.io/DIADEM-ontology/proj#person/Irène_Joliot-Curie> ;
    proj:hasFunding <https://cnherrera.github.io/DIADEM-ontology/proj#funding/PEPR-DIADEM> ;
    proj:hasLeadInstitution <https://cnherrera.github.io/DIADEM-ontology/proj#org/CNRS> ;
    proj:hasLeadPerson <https://cnherrera.github.io/DIADEM-ontology/proj#person/Henri_Becquerel> ;
    proj:hasPlatform <https://cnherrera.github.io/DIADEM-ontology/proj#platform/DATAPLAT>,
        <https://cnherrera.github.io/DIADEM-ontology/proj#platform/SCIENCEPLAT> ;
    proj:hasTargetedProject <https://cnherrera.github.io/DIADEM-ontology/proj#project/DIAMOND> ;
    proj:startDate "2023-01-01"^^xsd:date .

<https://cnherrera.github.io/DIADEM-ontology/proj#competence/Lise_Meitner_Data_engineering> a proj:Competence ;
    proj:competenceDomain "Data engineering"^^xsd:string ;
    proj:competenceLevel "expert"^^xsd:string .

<https://cnherrera.github.io/DIADEM-ontology/proj#competence/Lise_Meitner_Machine_learning> a proj:Competence ;
    proj:competenceDomain "Machine learning"^^xsd:string ;
    proj:competenceLevel "intermediate"^^xsd:string .

<https://cnherrera.github.io/DIADEM-ontology/proj#competence/Marie_Curie_Project_management> a proj:Competence ;
    proj:competenceDomain "Project management"^^xsd:string ;
    proj:competenceLevel "expert"^^xsd:string .

<https://cnherrera.github.io/DIADEM-ontology/proj#competence/Marie_Curie_Radiation_physics> a proj:Competence ;
    proj:competenceDomain "Radiation physics"^^xsd:string ;
    proj:competenceLevel "expert"^^xsd:string .

<https://cnherrera.github.io/DIADEM-ontology/proj#deliverable/DIAMOND_WP1_D1_1> a proj:Deliverable ;
    rdfs:label "Data Management Plan"^^xsd:string ;
    proj:deliverableType "report"^^xsd:string ;
    proj:description "Initial DMP covering all project data."^^xsd:string ;
    proj:dueDate "2024-06-30"^^xsd:date ;
    proj:identifier "D1.1"^^xsd:string .

<https://cnherrera.github.io/DIADEM-ontology/proj#deliverable/DIAMOND_WP1_D1_2> a proj:Deliverable ;
    rdfs:label "Mid-term report"^^xsd:string ;
    proj:deliverableType "report"^^xsd:string ;
    proj:description "18-month progress report."^^xsd:string ;
    proj:dueDate "2025-06-30"^^xsd:date ;
    proj:identifier "D1.2"^^xsd:string .

<https://cnherrera.github.io/DIADEM-ontology/proj#deliverable/DIAMOND_WP2_D2_1> a proj:Deliverable ;
    rdfs:label "Curated dataset v1"^^xsd:string ;
    proj:deliverableType "dataset"^^xsd:string ;
    proj:description "First release of the harmonised dataset."^^xsd:string ;
    proj:dueDate "2025-12-01"^^xsd:date ;
    proj:identifier "D2.1"^^xsd:string .

<https://cnherrera.github.io/DIADEM-ontology/proj#funding/PEPR-DIADEM> a proj:Funding ;
    proj:fundingAmount 30000000.0 ;
    proj:fundingCurrency "EUR"^^xsd:string ;
    proj:fundingSource "ANR / France 2030"^^xsd:string .

<https://cnherrera.github.io/DIADEM-ontology/proj#org/CEA> a proj:Organization ;
    rdfs:label "Commissariat à l'énergie atomique et aux énergies alternatives"^^xsd:string ;
    proj:acronym "CEA"^^xsd:string ;
    proj:rorID "https://ror.org/00jjx8s55"^^xsd:anyURI .

<https://cnherrera.github.io/DIADEM-ontology/proj#person/Henri_Becquerel> a proj:Person ;
    proj:email "h.becquerel@example.fr"^^xsd:string ;
    proj:firstName "Henri"^^xsd:string ;
    proj:lastName "Becquerel"^^xsd:string .

<https://cnherrera.github.io/DIADEM-ontology/proj#person/Irène_Joliot-Curie> a proj:Person ;
